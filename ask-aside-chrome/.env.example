# AskAside configuration (optional).
#
# Copy this file to `.env` in the same folder and fill in the values you need.
# The `.env` file is read at runtime and its values are used as defaults;
# anything saved through the extension's options page overrides them.
#
# Do NOT commit a real `.env` — it contains API keys (it is gitignored).

# Which provider to use: "anthropic" or "openrouter".
ASKASIDE_PROVIDER=anthropic

# Anthropic (Claude API directly). Key from platform.claude.com.
# Model is fixed to claude-opus-4-8.
ANTHROPIC_API_KEY=

# OpenRouter (free model choice). Key from openrouter.ai.
OPENROUTER_API_KEY=
# Any model ID from openrouter.ai/models, e.g. anthropic/claude-sonnet-4.5
OPENROUTER_MODEL=
# Optional: base URL of another OpenAI-compatible provider.
# Leave empty for OpenRouter (defaults to https://openrouter.ai/api/v1).
OPENROUTER_BASE_URL=
